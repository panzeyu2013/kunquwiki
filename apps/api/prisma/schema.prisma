generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 实体类型
enum EntityType {
  work
  person
  troupe
  venue
  event
  city
  article
  role
  topic
}

// 发布状态
enum PublishStatus {
  draft
  published
  archived
  pending_review
}

// 活动状态
enum EventStatus {
  announced
  scheduled
  completed
  cancelled
  postponed
}

// 剧目类型
enum WorkType {
  full_play
  excerpt
  adapted_piece
}

// 院团类型
enum TroupeType {
  troupe
  school
  research_org
}

// 活动类型
enum EventType {
  performance
  festival
  lecture
  memorial
}

// 文章类型
enum ArticleType {
  term
  costume
  music
  history
  technique
}

enum AssetType {
  image
  audio
  video
  document
}

// 审核状态
enum ReviewStatus {
  pending
  approved
  rejected
}

// 用户状态
enum UserStatus {
  active
  suspended
  pending
}

// 用户角色（权限身份，与 Role 实体无关）
enum UserRole {
  visitor
  bot
  editor
  reviewer
  admin
}

// 提案状态
enum ProposalStatus {
  pending
  approved
  rejected
}

// 人物身份标签
enum IdentityTerm {
  actor
  teacher
  director
  writer
  researcher
  promoter
}

// =====================
// 实体模块
// =====================

// 用户
model User {
  id              String           @id @default(cuid())
  username        String           @unique
  displayName     String
  email           String           @unique
  passwordHash    String
  status          UserStatus       @default(active)
  roles           UserRole[]       @default([editor])
  reputation      Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdEntities Entity[]         @relation("EntityCreatedBy")
  updatedEntities Entity[]         @relation("EntityUpdatedBy")
  revisions       EntityRevision[] @relation("RevisionEditor")
  reviewedChanges EntityRevision[] @relation("RevisionReviewer")
  proposals       EditProposal[]   @relation("ProposalAuthor")
  reviewedProposals EditProposal[] @relation("ProposalReviewer")
  auditLogs       AuditLog[]
  discussionPosts DiscussionPost[]
  discussionThreads DiscussionThread[]
}

// 统一实体总表
model Entity {
  id             String             @id @default(cuid())
  entityType     EntityType
  slug           String             @unique // 路径标识
  title          String
  subtitle       String?
  status         PublishStatus      @default(draft) // 发布状态
  visibility     String             @default("public") // 可见性
  coverImageId   String?            // 封面素材
  createdById    String
  updatedById    String
  publishedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      User               @relation("EntityCreatedBy", fields: [createdById], references: [id])
  updatedBy      User               @relation("EntityUpdatedBy", fields: [updatedById], references: [id])
  coverImage     MediaAsset?        @relation("EntityCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  aliases        EntityAlias[]
  content        EntityContent?
  revisions      EntityRevision[]
  work           Work?
  person         Person?
  troupe         Troupe?
  venue          Venue?
  event          Event?
  city           City?
  article        Article?
  roleRecord     Role?
  topic          Topic?
  sourceRefs     EntitySourceRef[]
  proposalRefs   EditProposal[]
  searchIndex    SearchIndex?
  outgoingRelations EntityRelation[] @relation("EntityRelationFrom")
  incomingRelations EntityRelation[] @relation("EntityRelationTo")
  discussionThreads DiscussionThread[]

}

model MediaAsset {
  id               String   @id @default(cuid())
  assetType        AssetType
  url              String
  mimeType         String?
  altText          String?
  width            Int?
  height           Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  coverForEntities Entity[] @relation("EntityCoverImage")
  posterForEvents  Event[]  @relation("EventPosterImage")
}

// 实体别名
model EntityAlias {
  id        String   @id @default(cuid())
  entityId  String
  alias     String
  aliasType String
  isPrimary Boolean  @default(false)
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, alias, aliasType])
}

// 实体内容（可渲染 Markdown）
model EntityContent {
  id           String   @id @default(cuid())
  entityId      String   @unique
  bodyMarkdown  String   // 正文 Markdown
  updatedAt     DateTime @updatedAt
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// 修订记录（审核通过时写入）
model EntityRevision {
  id                String       @id @default(cuid())
  entityId          String
  revisionNo        Int
  title             String
  bodyMarkdown      String?
  structuredDataJson Json?       // 提案结构化快照
  editSummary       String
  reviewStatus      ReviewStatus @default(pending)
  editorId          String
  reviewerId        String?
  reviewedAt        DateTime?
  createdAt         DateTime     @default(now())
  entity            Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  editor            User         @relation("RevisionEditor", fields: [editorId], references: [id])
  reviewer          User?        @relation("RevisionReviewer", fields: [reviewerId], references: [id])

  @@unique([entityId, revisionNo])
}

// 城市
model City {
  entityId    String   @id
  province    String
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  bornPeople  Person[] @relation("PersonBirthCity")
  troupes     Troupe[]
  venues      Venue[]
  events      Event[]

}

// 剧目/作品
model Work {
  entityId        String   @id
  workType        WorkType
  parentWorkId    String?
  originalAuthor  String?
  dynastyPeriod   String?
  genreNote       String?
  synopsis        String
  plot            String
  durationMinutes Int?
  firstKnownDate  String?
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  parentWork      Work?    @relation("WorkParent", fields: [parentWorkId], references: [entityId], onDelete: SetNull)
  childWorks      Work[]   @relation("WorkParent")
  roles           Role[]
  eventProgramItems EventProgramItem[]

}

// 人物（演员/研究者等真实人物，与 User 无关）
model Person {
  entityId        String   @id
  personTypeNote  String? // 人物类型说明
  gender          String?
  birthDate       DateTime?
  deathDate       DateTime?
  birthCityEntityId String?
  bio             String
  isLiving        Boolean?
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  birthCity       City?    @relation("PersonBirthCity", fields: [birthCityEntityId], references: [entityId], onDelete: SetNull)
  identities      PersonIdentity[]
  troupeMemberships PersonTroupeMembership[]
  eventParticipants EventParticipant[]
  performanceCasts PerformanceCast[]

}

// 院团
model Troupe {
  entityId        String   @id
  troupeType      TroupeType
  foundedDate     DateTime?
  dissolvedDate   DateTime?
  cityEntityId    String?
  cityText        String?
  regionText      String?
  description     String
  officialWebsite String?
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  cityRecord      City?    @relation(fields: [cityEntityId], references: [entityId], onDelete: SetNull)
  memberships     PersonTroupeMembership[]
  eventTroupes    EventTroupe[]

}

// 场馆
model Venue {
  entityId    String   @id
  venueType   String
  countryText String   @default("中国")
  cityEntityId String?
  regionText  String
  cityText    String
  address     String
  latitude    Decimal?
  longitude   Decimal?
  capacity    Int?
  description String?
  entity      Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  cityRecord  City?    @relation(fields: [cityEntityId], references: [entityId], onDelete: SetNull)
  events      Event[]

}

// 演出/活动
model Event {
  entityId        String      @id
  eventType       EventType
  businessStatus  EventStatus
  startAt         DateTime
  endAt           DateTime?
  timezone        String      @default("Asia/Shanghai")
  cityEntityId    String?
  venueEntityId   String?
  organizerText   String?
  ticketUrl       String?
  durationText    String?
  ticketStatus    String?
  noteText        String?
  posterImageId   String?
  lastVerifiedAt  DateTime?
  entity          Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)
  city            City?       @relation(fields: [cityEntityId], references: [entityId], onDelete: SetNull)
  venue           Venue?      @relation(fields: [venueEntityId], references: [entityId], onDelete: SetNull)
  posterImage     MediaAsset? @relation("EventPosterImage", fields: [posterImageId], references: [id], onDelete: SetNull)
  programItems    EventProgramItem[]
  troupes         EventTroupe[]
  participants   EventParticipant[]

}

// 文章/词条
model Article {
  entityId        String   @id
  articleType     ArticleType
  abstract        String?
  difficultyLevel String?
  bodySourceType  String?
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

}

// 角色（剧中角色/行当等，与 UserRole 无关）
model Role {
  entityId       String   @id
  workEntityId   String?  // 关联剧目（可空）
  roleCategory   String?  // 角色类别/行当
  description    String?
  entity         Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  work           Work?    @relation(fields: [workEntityId], references: [entityId], onDelete: SetNull)
  performanceCasts PerformanceCast[]

}

// 专题
model Topic {
  entityId      String   @id
  topicType     String
  heroText      String?
  layoutJson    Json?
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

}

// =====================
// 关系模块
// =====================

// 人物身份/头衔
model PersonIdentity {
  id               String   @id @default(cuid())
  personEntityId   String
  identityTerm     IdentityTerm
  startDate        DateTime?
  endDate          DateTime?
  person           Person   @relation(fields: [personEntityId], references: [entityId], onDelete: Cascade)
}

// 人员与院团关系
model PersonTroupeMembership {
  id              String   @id @default(cuid())
  personEntityId  String
  troupeEntityId  String
  membershipRole  String
  startDate       DateTime?
  endDate         DateTime?
  isCurrent       Boolean  @default(false)
  person          Person   @relation(fields: [personEntityId], references: [entityId], onDelete: Cascade)
  troupe          Troupe   @relation(fields: [troupeEntityId], references: [entityId], onDelete: Cascade)
}

// 节目单条目
model EventProgramItem {
  id              String   @id @default(cuid())
  eventEntityId   String
  workEntityId    String?
  titleOverride   String?
  sequenceNo      Int
  durationMinutes Int?
  notes           String?
  event           Event    @relation(fields: [eventEntityId], references: [entityId], onDelete: Cascade)
  work            Work?    @relation(fields: [workEntityId], references: [entityId], onDelete: SetNull)
  casts           PerformanceCast[]

  @@unique([eventEntityId, sequenceNo])
}

// 演出卡司（节目单条目中的演员/角色）
model PerformanceCast {
  id                 String           @id @default(cuid())
  eventProgramItemId String
  roleEntityId       String?
  personEntityId     String?
  castNote           String?
  programItem        EventProgramItem @relation(fields: [eventProgramItemId], references: [id], onDelete: Cascade)
  role               Role?            @relation(fields: [roleEntityId], references: [entityId], onDelete: Cascade)
  person             Person?          @relation(fields: [personEntityId], references: [entityId], onDelete: Cascade)

  @@unique([eventProgramItemId, roleEntityId, personEntityId])
}

// 活动参与者（与节目单并行的参与名单）
model EventParticipant {
  id                String   @id @default(cuid())
  eventEntityId     String
  personEntityId    String?
  participationRole String
  creditedAs        String?
  sortOrder         Int      @default(0)
  event             Event    @relation(fields: [eventEntityId], references: [entityId], onDelete: Cascade)
  person            Person?  @relation(fields: [personEntityId], references: [entityId], onDelete: Cascade)

  @@unique([eventEntityId, personEntityId, participationRole])
}

// 活动-剧团关系（不区分角色）
model EventTroupe {
  id            String   @id @default(cuid())
  eventEntityId String
  troupeEntityId String
  sortOrder     Int      @default(0)
  event         Event    @relation(fields: [eventEntityId], references: [entityId], onDelete: Cascade)
  troupe        Troupe   @relation(fields: [troupeEntityId], references: [entityId], onDelete: Cascade)

  @@unique([eventEntityId, troupeEntityId])
}

// 实体关系（可用于代表作、关联条目等）
model EntityRelation {
  id             String   @id @default(cuid())
  fromEntityId   String
  toEntityId     String
  relationType   String
  note           String?
  sortOrder      Int      @default(0)
  fromEntity     Entity   @relation("EntityRelationFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity       Entity   @relation("EntityRelationTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@unique([fromEntityId, toEntityId, relationType])
}

// 来源
model Source {
  id               String            @id @default(cuid())
  sourceType       String
  title            String
  publisher        String?
  author           String?
  sourceUrl        String?
  publicationDate  DateTime?
  reliabilityLevel String
  archivedUrl      String?
  notes            String?
  entityRefs       EntitySourceRef[]

}

// 实体与来源的引用关系
model EntitySourceRef {
  id           String   @id @default(cuid())
  entityId      String
  sourceId      String
  refNote       String?
  citationText  String?
  sortOrder     Int      @default(0)
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  source        Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([entityId, sourceId])
}

// 编辑提案（提交后进入审核队列）
model EditProposal {
  id             String         @id @default(cuid())
  entityId       String
  proposerId     String
  proposalType   String
  payloadJson    Json           // 提案内容快照（审核时回放并写回）
  status         ProposalStatus @default(pending)
  reviewerId     String?
  reviewComment  String?
  createdAt      DateTime       @default(now())
  reviewedAt     DateTime?
  entity         Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  proposer       User           @relation("ProposalAuthor", fields: [proposerId], references: [id])
  reviewer       User?          @relation("ProposalReviewer", fields: [reviewerId], references: [id])

}

// 讨论主题
model DiscussionThread {
  id          String          @id @default(cuid())
  entityId    String
  title       String
  createdById String
  status      String          @default("open")
  createdAt   DateTime        @default(now())
  entity      Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  createdBy   User            @relation(fields: [createdById], references: [id])
  posts       DiscussionPost[]

}

// 讨论回复
model DiscussionPost {
  id         String           @id @default(cuid())
  threadId    String
  authorId    String
  body        String
  createdAt   DateTime        @default(now())
  thread      DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User            @relation(fields: [authorId], references: [id])

}

// 搜索索引（派生数据）
model SearchIndex {
  id          String   @id @default(cuid())
  entityId     String   @unique
  entityType   EntityType
  title        String
  searchText   String
  updatedAt    DateTime @updatedAt
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

}

// 审计日志
model AuditLog {
  id          String   @id @default(cuid())
  actorId      String
  actionType   String
  targetType   String
  targetId     String
  payloadJson  Json?   // 审计上下文
  createdAt    DateTime @default(now())
  actor        User     @relation(fields: [actorId], references: [id])

}

